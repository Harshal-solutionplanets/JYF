## Firebase Web App config (from Firebase Console > Project settings > Your apps)
REACT_APP_FIREBASE_API_KEY=CHANGE_ME
REACT_APP_FIREBASE_AUTH_DOMAIN=CHANGE_ME
REACT_APP_FIREBASE_PROJECT_ID=demo-jyf
REACT_APP_FIREBASE_STORAGE_BUCKET=CHANGE_ME
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=CHANGE_ME
REACT_APP_FIREBASE_APP_ID=CHANGE_ME

## Local dev
REACT_APP_USE_EMULATORS=true
REACT_APP_FUNCTIONS_REGION=us-central1

## Optional: override where the API is hosted (Functions URL)
# REACT_APP_API_BASE_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/api

